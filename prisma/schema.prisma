  voidedAt              DateTime? @map("VoidedAt") @db.Timestamptz
  voidReason            String?   @map("VoidReason") @db.VarChar(500)
  createdBy             String?   @map("CreatedBy") @db.Uuid
  approvedBy            String?   @map("ApprovedBy") @db.Uuid
  paidAt                DateTime? @map("PaidAt") @db.Timestamptz
  createdAt             DateTime  @default(now()) @map("CreatedAt") @db.Timestamptz

  employee       Employee        @relation(fields: [employeeId], references: [id])
  payrollDetails PayrollDetail[]

  @@map("EmployeeTerminations")
  @@schema("hr")
}

model LeaveType {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                   String   @unique @db.VarChar(100)
  /// VACACIONES | PERMISO_CON_GOCE | PERMISO_SIN_GOCE | BAJA_MEDICA | INCAPACIDAD_LABORAL | MATERNIDAD | PATERNIDAD | SUSPENSION_DISCIPLINARIA
  category               String   @db.VarChar(40)
  maxDaysPerYear         Decimal? @map("MaxDaysPerYear") @db.Decimal(5, 1)
  requiresDocument       Boolean  @default(false) @map("RequiresDocument")
  isPaid                 Boolean  @default(true) @map("IsPaid")
  affectsVacationAccrual Boolean  @default(false) @map("AffectsVacationAccrual")
  legalBasis             String?  @map("LegalBasis") @db.VarChar(200)
  isActive               Boolean  @default(true) @map("IsActive")
  createdAt              DateTime @default(now()) @map("CreatedAt") @db.Timestamptz

  leaveRequests LeaveRequest[]

  @@map("LeaveTypes")
  @@schema("hr")
}

model LeaveRequest {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId         String    @map("EmployeeId") @db.Uuid
  leaveTypeId        String    @map("LeaveTypeId") @db.Uuid
  startDate          DateTime  @map("StartDate") @db.Date
  endDate            DateTime  @map("EndDate") @db.Date
  daysRequested      Decimal   @map("DaysRequested") @db.Decimal(5, 1)
  halfDay            Boolean   @default(false) @map("HalfDay")
  halfDayPeriod      String?   @map("HalfDayPeriod") @db.VarChar(10)
  reason             String?   @db.Text
  documentUrl        String?   @map("DocumentUrl") @db.VarChar(500)
  /// PENDIENTE | APROBADA | RECHAZADA | EN_GOCE
  status             String    @default("PENDIENTE") @db.VarChar(20)
  vacationPayAmount  Decimal?  @map("VacationPayAmount") @db.Decimal(10, 2)
  vacationSurcharge  Decimal?  @map("VacationSurcharge") @db.Decimal(10, 2)
  requestedAt        DateTime  @default(now()) @map("RequestedAt") @db.Timestamptz
  reviewedBy         String?   @map("ReviewedBy") @db.Uuid
  reviewedAt         DateTime? @map("ReviewedAt") @db.Timestamptz
  reviewNotes        String?   @map("ReviewNotes") @db.Text
  approvedBy         String?   @map("ApprovedBy") @db.Uuid
  approvedAt         DateTime? @map("ApprovedAt") @db.Timestamptz
  processedInPayroll Boolean   @default(false) @map("ProcessedInPayroll")
  payrollDetailId    String?   @map("PayrollDetailId") @db.Uuid
  createdAt          DateTime  @default(now()) @map("CreatedAt") @db.Timestamptz
  updatedAt          DateTime  @default(now()) @map("UpdatedAt") @db.Timestamptz

  employee      Employee       @relation(fields: [employeeId], references: [id])
  leaveType     LeaveType      @relation(fields: [leaveTypeId], references: [id])
  payrollDetail PayrollDetail? @relation(fields: [payrollDetailId], references: [id])

  @@index([employeeId], map: "IdxLeaveRequestsEmployee")
  @@index([status], map: "IdxLeaveRequestsStatus")
  @@index([startDate, endDate], map: "IdxLeaveRequestsDates")
  @@map("LeaveRequests")
  @@schema("hr")
}

model VacationBalance {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId       String    @map("EmployeeId") @db.Uuid
  year             Int
  daysEarned       Decimal   @default(15) @map("DaysEarned") @db.Decimal(5, 1)
  daysTaken        Decimal   @default(0) @map("DaysTaken") @db.Decimal(5, 1)
  lastVacationDate DateTime? @map("LastVacationDate") @db.Date
  nextVacationDue  DateTime? @map("NextVacationDue") @db.Date
  updatedAt        DateTime  @default(now()) @map("UpdatedAt") @db.Timestamptz

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, year])
  @@map("VacationBalances")
  @@schema("hr")
}

model IsrDeclaration {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  year           Int
  month          Int       @db.SmallInt
  periodId       String?   @map("PeriodId") @db.Uuid
  totalTaxable   Decimal?  @map("TotalTaxable") @db.Decimal(12, 2)
  totalIsr       Decimal?  @map("TotalIsr") @db.Decimal(12, 2)
  submissionDate DateTime? @map("SubmissionDate") @db.Date
  mhReference    String?   @map("MhReference") @db.VarChar(50)
  /// PENDIENTE | ENVIADA | ACEPTADA
  status         String    @default("PENDIENTE") @db.VarChar(30)
  fileUrl        String?   @map("FileUrl") @db.VarChar(500)
  createdBy      String?   @map("CreatedBy") @db.Uuid
  createdAt      DateTime  @default(now()) @map("CreatedAt") @db.Timestamptz

  period PayrollPeriod? @relation(fields: [periodId], references: [id])

  @@unique([year, month])
  @@map("IsrDeclarations")
  @@schema("hr")
}

// =============================================================================
// SCHEMA: system — Configuración, Seguridad y Auditoría
// =============================================================================

model Setting {
  key         String   @id @map("Key") @db.VarChar(100)
  value       String   @map("Value") @db.Text
  description String?  @map("Description") @db.VarChar(300)
  /// Si es true, puede exponerse en la API pública sin autenticación
  isPublic    Boolean  @default(false) @map("IsPublic")
  updatedAt   DateTime @default(now()) @map("UpdatedAt") @db.Timestamptz

  @@map("Settings")
  @@schema("system")
}

/// Impresoras configuradas por la caja WPF.
model Printer {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @map("Id") @db.Uuid
  name           String   @map("Name") @db.VarChar(200)
  connectionType String   @default("USB") @map("ConnectionType") @db.VarChar(10)
  ipAddress      String?  @map("IpAddress") @db.VarChar(15)
  networkPort    Int?     @map("NetworkPort")
  paperWidth     Int      @default(80) @map("PaperWidth") @db.SmallInt
  isDefault      Boolean  @default(false) @map("IsDefault")
  isActive       Boolean  @default(true) @map("IsActive")
  createdAt      DateTime @default(now()) @map("CreatedAt") @db.Timestamptz
  updatedAt      DateTime @default(now()) @map("UpdatedAt") @db.Timestamptz

  @@map("Printers")
  @@schema("system")
}

/// Usuarios del panel administrativo web. No se usa en WPF.
model WebUser {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username     String    @unique @map("Username") @db.VarChar(50)
  email        String    @unique @map("Email") @db.VarChar(100)
  passwordHash String    @map("PasswordHash")
  /// ADMIN | ACCOUNTANT | OWNER
  role         String    @default("ADMIN") @map("Role") @db.VarChar(20)
  employeeId   String?   @map("EmployeeId") @db.Uuid
  isActive     Boolean   @default(true) @map("IsActive")
  lastLoginAt  DateTime? @map("LastLoginAt") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("CreatedAt") @db.Timestamptz
  updatedAt    DateTime  @default(now()) @map("UpdatedAt") @db.Timestamptz

  @@map("WebUsers")
  @@schema("system")
}

model AuditLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tableName String   @map("TableName") @db.VarChar(100)
  recordId  String   @map("RecordId") @db.VarChar(50)
  /// INSERT | UPDATE | DELETE
  action    String   @db.VarChar(10)
  oldData   Json?    @map("OldData")
  newData   Json?    @map("NewData")
  userId    String?  @map("UserId") @db.Uuid
  ipAddress String?  @map("IpAddress") @db.VarChar(45)
  userAgent String?  @map("UserAgent") @db.VarChar(300)
  createdAt DateTime @default(now()) @map("CreatedAt") @db.Timestamptz

  @@index([tableName, recordId], map: "IdxAuditLogRecord")
  @@index([userId], map: "IdxAuditLogUser")
  @@index([createdAt], map: "IdxAuditLogCreatedAt")
  @@map("AuditLog")
  @@schema("system")
}
