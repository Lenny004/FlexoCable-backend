// =============================================================================
// FlexoCable SV — Prisma schema v3.0 (admin API / Node)
// Esquemas: public, purchasing, sales, dte, fiscal, hr, system
// WPF caja usa EF Core sobre la misma base PostgreSQL/Supabase.
// UUID gen_random_uuid() en todas las tablas de negocio.
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "purchasing", "sales", "dte", "fiscal", "hr", "system"]
}

// =============================================================================
// SCHEMA: public — Catálogo maestro de productos
// =============================================================================

model MeasurementType {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code      String @unique @db.VarChar(10)
  name      String @db.VarChar(50)
  unitLabel String @map("UnitLabel") @db.VarChar(20)
  decimals  Int    @default(0) @db.SmallInt

  products Product[]

  @@map("MeasurementTypes")
  @@schema("public")
}

model Family {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String   @unique @db.VarChar(10)
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(300)
  isActive    Boolean  @default(true) @map("IsActive")
  createdAt   DateTime @default(now()) @map("CreatedAt") @db.Timestamptz
  updatedAt   DateTime @default(now()) @map("UpdatedAt") @db.Timestamptz

  subfamilies Subfamily[]
  products    Product[]

  @@map("Families")
  @@schema("public")
}

model Subfamily {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  familyId    String   @map("FamilyId") @db.Uuid
  code        String   @db.VarChar(10)
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(300)
  isActive    Boolean  @default(true) @map("IsActive")
  createdAt   DateTime @default(now()) @map("CreatedAt") @db.Timestamptz
  updatedAt   DateTime @default(now()) @map("UpdatedAt") @db.Timestamptz

  family   Family    @relation(fields: [familyId], references: [id])
  products Product[]

  @@unique([familyId, code])
  @@index([familyId], map: "IdxSubfamiliesFamily")
  @@map("Subfamilies")
  @@schema("public")
}

/// Datos fiscales básicos del cliente. Sin módulo CxC — solo para DTE y trazabilidad.
model Customer {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// CF = consumidor final | CCF = contribuyente (requiere NIT+NRC)
  customerType String   @default("CF") @map("CustomerType") @db.VarChar(5)
  name         String   @db.VarChar(200)
  dui          String?  @unique @map("Dui") @db.VarChar(15)
  nit          String?  @unique @map("Nit") @db.VarChar(20)
  nrc          String?  @unique @map("Nrc") @db.VarChar(20)
  phone        String?  @db.VarChar(20)
  email        String?  @db.VarChar(100)
  address      String?  @db.VarChar(300)
  municipality String?  @db.VarChar(100)
  department   String?  @db.VarChar(50)
  isActive     Boolean  @default(true) @map("IsActive")
  createdAt    DateTime @default(now()) @map("CreatedAt") @db.Timestamptz
  updatedAt    DateTime @default(now()) @map("UpdatedAt") @db.Timestamptz

  orders Order[]

  @@index([nit], map: "IdxCustomersNit")
  @@index([nrc], map: "IdxCustomersNrc")
  @@map("Customers")
  @@schema("public")
}

model Product {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code              String   @unique @db.VarChar(30)
  barcode           String?  @unique @db.VarChar(50)
  description       String   @db.VarChar(200)
  familyId          String   @map("FamilyId") @db.Uuid
  subfamilyId       String?  @map("SubfamilyId") @db.Uuid
  measurementTypeId String   @map("MeasurementTypeId") @db.Uuid
  /// Precio de venta vigente
  salePrice         Decimal  @default(0) @map("SalePrice") @db.Decimal(12, 2)
  /// Costo promedio ponderado — actualizado automáticamente al recibir compras
  costPrice         Decimal  @default(0) @map("CostPrice") @db.Decimal(12, 4)
  currentStock      Decimal  @default(0) @map("CurrentStock") @db.Decimal(12, 3)
  minStock          Decimal  @default(0) @map("MinStock") @db.Decimal(12, 3)
  maxStock          Decimal? @map("MaxStock") @db.Decimal(12, 3)
  reorderPoint      Decimal? @map("ReorderPoint") @db.Decimal(12, 3)
  isActive          Boolean  @default(true) @map("IsActive")
  notes             String?  @db.Text
  createdAt         DateTime @default(now()) @map("CreatedAt") @db.Timestamptz
  updatedAt         DateTime @default(now()) @map("UpdatedAt") @db.Timestamptz

  family               Family              @relation(fields: [familyId], references: [id])
  subfamily            Subfamily?          @relation(fields: [subfamilyId], references: [id])
  measurementType      MeasurementType     @relation(fields: [measurementTypeId], references: [id])
  orderDetails         OrderDetail[]
  inventoryMovements   InventoryMovement[]
  purchaseOrderDetails PurchaseOrderDetail[]
  stockAlerts          StockAlert[]

  @@index([familyId], map: "IdxProductsFamily")
  @@index([subfamilyId], map: "IdxProductsSubfamily")
  @@map("Products")
  @@schema("public")
}

model StockAlert {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @map("Id") @db.Uuid
  productId    String    @map("ProductId") @db.Uuid
  currentStock Decimal   @map("CurrentStock") @db.Decimal(12, 3)
  minStock     Decimal   @map("MinStock") @db.Decimal(12, 3)
  isResolved   Boolean   @default(false) @map("IsResolved")
  resolvedAt   DateTime? @map("ResolvedAt") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("CreatedAt") @db.Timestamptz

  product Product @relation(fields: [productId], references: [id])

  @@index([productId], map: "IdxStockAlertsProduct")
  @@map("StockAlerts")
  @@schema("public")
}

// =============================================================================
// SCHEMA: purchasing — Compras y Proveedores
// =============================================================================

model Supplier {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @db.VarChar(200)
  tradeName   String?  @map("TradeName") @db.VarChar(200)
  nit         String?  @unique @map("Nit") @db.VarChar(20)
  nrc         String?  @unique @map("Nrc") @db.VarChar(20)
  contactName String?  @map("ContactName") @db.VarChar(150)
  phone       String?  @db.VarChar(20)
  email       String?  @db.VarChar(100)
  address     String?  @db.VarChar(300)
  municipality String? @db.VarChar(100)
  department  String?  @db.VarChar(50)
  /// SV = nacional, otro código ISO = importación
  country     String   @default("SV") @db.VarChar(5)
  creditDays  Int      @default(0) @map("CreditDays")
  isActive    Boolean  @default(true) @map("IsActive")
  notes       String?  @db.Text
  createdAt   DateTime @default(now()) @map("CreatedAt") @db.Timestamptz
  updatedAt   DateTime @default(now()) @map("UpdatedAt") @db.Timestamptz

  purchaseOrders PurchaseOrder[]

  @@index([nit], map: "IdxSuppliersNit")
  @@map("Suppliers")
  @@schema("purchasing")
}

model PurchaseOrder {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  supplierId        String    @map("SupplierId") @db.Uuid
  employeeId        String    @map("EmployeeId") @db.Uuid
  /// Número de documento del proveedor (factura/CCF recibido)
  supplierDocNumber String?   @map("SupplierDocNumber") @db.VarChar(50)
  /// Tipo de documento recibido: CCF, FAC, OTRO
  supplierDocType   String?   @map("SupplierDocType") @db.VarChar(10)
  /// BORRADOR → CONFIRMADA → RECIBIDA → CANCELADA
  status            String    @default("BORRADOR") @db.VarChar(20)
  subtotal          Decimal   @default(0) @db.Decimal(12, 2)
  taxAmount         Decimal   @default(0) @map("TaxAmount") @db.Decimal(12, 2)
  total             Decimal   @default(0) @db.Decimal(12, 2)
  notes             String?   @db.Text
  expectedDate      DateTime? @map("ExpectedDate") @db.Date
  receivedAt        DateTime? @map("ReceivedAt") @db.Timestamptz
  receivedById      String?   @map("ReceivedById") @db.Uuid
  createdAt         DateTime  @default(now()) @map("CreatedAt") @db.Timestamptz
  updatedAt         DateTime  @default(now()) @map("UpdatedAt") @db.Timestamptz

  supplier           Supplier              @relation(fields: [supplierId], references: [id])
  details            PurchaseOrderDetail[]
  inventoryMovements InventoryMovement[]

  @@index([supplierId], map: "IdxPurchaseOrdersSupplier")
  @@index([status], map: "IdxPurchaseOrdersStatus")
  @@map("PurchaseOrders")
  @@schema("purchasing")
}

model PurchaseOrderDetail {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  purchaseOrderId String  @map("PurchaseOrderId") @db.Uuid
  productId       String  @map("ProductId") @db.Uuid
  quantity        Decimal @db.Decimal(12, 3)
  unitCost        Decimal @map("UnitCost") @db.Decimal(12, 4)
  taxRate         Decimal @default(0.13) @map("TaxRate") @db.Decimal(5, 4)
  subtotal        Decimal @db.Decimal(12, 2)
  total           Decimal @db.Decimal(12, 2)
  notes           String? @db.VarChar(300)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])

  @@index([purchaseOrderId], map: "IdxPODetailsOrder")
  @@index([productId], map: "IdxPODetailsProduct")
  @@map("PurchaseOrderDetails")
  @@schema("purchasing")
}

// =============================================================================
// SCHEMA: sales — Ventas, Caja e Inventario
// =============================================================================

model CashSession {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId            String    @map("EmployeeId") @db.Uuid
  cashRegisterCode      String    @default("CAJA-01") @map("CashRegisterCode") @db.VarChar(50)
  openedAt              DateTime  @default(now()) @map("OpenedAt") @db.Timestamptz
  closedAt              DateTime? @map("ClosedAt") @db.Timestamptz
  openingAmount         Decimal   @default(0) @map("OpeningAmount") @db.Decimal(12, 2)
  closingDeclaredAmount Decimal?  @map("ClosingDeclaredAmount") @db.Decimal(12, 2)
  closingExpectedAmount Decimal?  @map("ClosingExpectedAmount") @db.Decimal(12, 2)
  difference            Decimal?  @db.Decimal(12, 2)
  /// ABIERTA | CERRADA | CANCELADA
  status                String    @default("ABIERTA") @db.VarChar(20)
  notes                 String?   @db.Text
  createdAt             DateTime  @default(now()) @map("CreatedAt") @db.Timestamptz
  updatedAt             DateTime  @default(now()) @map("UpdatedAt") @db.Timestamptz

  employee Employee  @relation(fields: [employeeId], references: [id])
  orders   Order[]
  payments Payment[]

  // La regla real es parcial: una sola sesion ABIERTA por empleado/caja.
  // Prisma no modela indices parciales; debe crearse con SQL raw en migracion.
  @@index([employeeId, cashRegisterCode], map: "IdxCashSessionEmployeeRegister")
  @@index([status], map: "IdxCashSessionStatus")
  @@index([openedAt], map: "IdxCashSessionOpened")
  @@map("CashSessions")
  @@schema("sales")
}

model Order {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId      String   @map("EmployeeId") @db.Uuid
  cashSessionId   String?  @map("CashSessionId") @db.Uuid
  /// customerId solo aplica para CCF (clientes con datos fiscales)
  customerId      String?  @map("CustomerId") @db.Uuid
  /// VENTA_CAJA = mostrador | ORDEN_CONFECCION = taller
  orderType       String   @default("VENTA_CAJA") @map("OrderType") @db.VarChar(20)
  /// Clave de idempotencia desde el cliente WPF
  clientRequestId String   @unique @default(dbgenerated("gen_random_uuid()")) @map("ClientRequestId") @db.Uuid
  /// PENDIENTE | COMPLETADA | CANCELADA
  status          String   @default("PENDIENTE") @db.VarChar(20)
  subtotal        Decimal  @default(0) @db.Decimal(12, 2)
  taxAmount       Decimal  @default(0) @map("TaxAmount") @db.Decimal(12, 2)
  total           Decimal  @default(0) @db.Decimal(12, 2)
  notes           String?  @db.Text
  createdAt       DateTime @default(now()) @map("CreatedAt") @db.Timestamptz
  updatedAt       DateTime @default(now()) @map("UpdatedAt") @db.Timestamptz

  employee    Employee     @relation(fields: [employeeId], references: [id])
  cashSession CashSession? @relation(fields: [cashSessionId], references: [id])
  customer    Customer?    @relation(fields: [customerId], references: [id])
  details     OrderDetail[]
  payments    Payment[]
  dteIssued   DteIssued[]

  @@index([employeeId], map: "IdxOrdersEmployee")
  @@index([cashSessionId], map: "IdxOrdersCashSession")
  @@index([status], map: "IdxOrdersStatus")
  @@index([createdAt], map: "IdxOrdersCreatedAt")
  @@map("Orders")
  @@schema("sales")
}

model OrderDetail {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId   String  @map("OrderId") @db.Uuid
  productId String  @map("ProductId") @db.Uuid
  quantity  Decimal @db.Decimal(12, 3)
  unitPrice Decimal @map("UnitPrice") @db.Decimal(12, 2)
  /// Costo congelado al momento de la venta para cálculo de margen
  unitCost  Decimal @default(0) @map("UnitCost") @db.Decimal(12, 4)
  subtotal  Decimal @db.Decimal(12, 2)
  notes     String? @db.VarChar(300)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId], map: "IdxOrderDetailsOrder")
  @@index([productId], map: "IdxOrderDetailsProduct")
  @@map("OrderDetails")
  @@schema("sales")
}

model Payment {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId       String   @map("OrderId") @db.Uuid
  cashSessionId String?  @map("CashSessionId") @db.Uuid
  /// EFECTIVO | TARJETA | TRANSFERENCIA | OTRO
  method        String   @db.VarChar(20)
  amount        Decimal  @db.Decimal(12, 2)
  reference     String?  @db.VarChar(100)
  createdAt     DateTime @default(now()) @map("CreatedAt") @db.Timestamptz

  order       Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  cashSession CashSession? @relation(fields: [cashSessionId], references: [id])

  @@index([orderId], map: "IdxPaymentsOrder")
  @@index([cashSessionId], map: "IdxPaymentsSession")
  @@map("Payments")
  @@schema("sales")
}

/// Kardex valorado — inmutable. Cada fila es un movimiento de inventario.
model InventoryMovement {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId       String   @map("ProductId") @db.Uuid
  /// VENTA | DEVOLUCION_VENTA | ENTRADA_COMPRA | AJUSTE_ENTRADA | AJUSTE_SALIDA
  movementType    String   @map("MovementType") @db.VarChar(30)
  /// Positivo = entrada, negativo = salida
  quantity        Decimal  @db.Decimal(12, 3)
  unitCost        Decimal  @default(0) @map("UnitCost") @db.Decimal(12, 4)
  totalCost       Decimal  @default(0) @map("TotalCost") @db.Decimal(12, 4)
  /// Stock antes y después del movimiento (desnormalizado para Kardex rápido)
  stockBefore     Decimal  @map("StockBefore") @db.Decimal(12, 3)
  stockAfter      Decimal  @map("StockAfter") @db.Decimal(12, 3)
  orderId         String?  @map("OrderId") @db.Uuid
  purchaseOrderId String?  @map("PurchaseOrderId") @db.Uuid
  employeeId      String?  @map("EmployeeId") @db.Uuid
  reason          String?  @db.VarChar(300)
  createdAt       DateTime @default(now()) @map("CreatedAt") @db.Timestamptz

  product       Product        @relation(fields: [productId], references: [id])
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])

  @@index([productId, createdAt], map: "IdxInvMovProductDate")
  @@index([movementType], map: "IdxInvMovType")
  @@index([orderId], map: "IdxInvMovOrder")
  @@index([purchaseOrderId], map: "IdxInvMovPO")
  @@map("InventoryMovements")
  @@schema("public")
}

// =============================================================================
// SCHEMA: dte — Facturación Electrónica
// =============================================================================

/// Configuración del emisor DTE. Solo debe existir un registro activo.
model DteConfig {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  emisorNit          String   @map("EmisorNit") @db.VarChar(20)
  emisorNrc          String   @map("EmisorNrc") @db.VarChar(20)
  emisorName         String   @map("EmisorName") @db.VarChar(250)
  emisorTradeName    String?  @map("EmisorTradeName") @db.VarChar(250)
  actividadEconomica String   @map("ActividadEconomica") @db.VarChar(10)
  addressLine        String   @map("AddressLine") @db.VarChar(300)
  municipality       String   @map("Municipality") @db.VarChar(100)
  department         String   @map("Department") @db.VarChar(50)
  phone              String?  @db.VarChar(20)
  email              String?  @db.VarChar(100)
  /// 00 = pruebas | 01 = producción
  ambiente           String   @default("00") @db.VarChar(5)
  isActive           Boolean  @default(true) @map("IsActive")
  createdAt          DateTime @default(now()) @map("CreatedAt") @db.Timestamptz
  updatedAt          DateTime @default(now()) @map("UpdatedAt") @db.Timestamptz

  @@map("DteConfig")
  @@schema("dte")
}

model DteIssued {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId        String?   @map("OrderId") @db.Uuid
  /// 01=FAC CF | 03=CCF | 05=Nota Crédito | 06=Sujeto Excluido | 11=FAC Exportación
  dteType        String    @map("DteType") @db.VarChar(5)
  generationCode String    @unique @default(dbgenerated("gen_random_uuid()")) @map("GenerationCode") @db.Uuid
  controlNumber  String    @unique @map("ControlNumber") @db.VarChar(40)
  /// PENDIENTE | PROCESADO | RECHAZADO | CONTINGENCIA
  mhStatus       String    @default("PENDIENTE") @map("MhStatus") @db.VarChar(20)
  mhResponse     String?   @map("MhResponse") @db.Text
  mhSello        String?   @map("MhSello") @db.Text
  /// FK al DTE original para notas de crédito (DTE-05)
  relatedDteId   String?   @map("RelatedDteId") @db.Uuid
  ambiente       String    @default("00") @db.VarChar(5)
  jsonPayload    String?   @map("JsonPayload") @db.Text
  pdfUrl         String?   @map("PdfUrl") @db.VarChar(500)
  /// Montos para libro de IVA
  totalExenta    Decimal   @default(0) @map("TotalExenta") @db.Decimal(12, 2)
  totalGravada   Decimal   @default(0) @map("TotalGravada") @db.Decimal(12, 2)
  totalIva       Decimal   @default(0) @map("TotalIva") @db.Decimal(12, 2)
  totalPagar     Decimal   @default(0) @map("TotalPagar") @db.Decimal(12, 2)
  reprints       Int       @default(0)
  issuedAt       DateTime  @default(now()) @map("IssuedAt") @db.Timestamptz
  processedAt    DateTime? @map("ProcessedAt") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("CreatedAt") @db.Timestamptz

  order       Order?          @relation(fields: [orderId], references: [id])
  relatedDte  DteIssued?      @relation("DteRelation", fields: [relatedDteId], references: [id])
  creditNotes DteIssued[]     @relation("DteRelation")
  contingency DteContingency?

  @@index([orderId], map: "IdxDteIssuedOrder")
  @@index([mhStatus], map: "IdxDteIssuedStatus")
  @@index([dteType], map: "IdxDteIssuedType")
  @@index([issuedAt], map: "IdxDteIssuedAt")
  @@map("DteIssued")
  @@schema("dte")
}

/// Cola de reintentos para DTEs en contingencia o rechazados temporalmente.
model DteContingency {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dteId        String    @unique @map("DteId") @db.Uuid
  attemptCount Int       @default(0) @map("AttemptCount")
  lastError    String?   @map("LastError") @db.Text
  nextRetryAt  DateTime? @map("NextRetryAt") @db.Timestamptz
  resolvedAt   DateTime? @map("ResolvedAt") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("CreatedAt") @db.Timestamptz
  updatedAt    DateTime  @default(now()) @map("UpdatedAt") @db.Timestamptz

  dte DteIssued @relation(fields: [dteId], references: [id])

  @@index([nextRetryAt], map: "IdxContingencyRetry")
  @@map("DteContingency")
  @@schema("dte")
}

// =============================================================================
// SCHEMA: fiscal — Libros de IVA
// =============================================================================

/// Registro de libros de IVA generados. Los datos reales se leen de DteIssued.
model IvaReport {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  year         Int
  month        Int       @db.SmallInt
  /// VENTAS_CF | VENTAS_CCF | COMPRAS
  reportType   String    @map("ReportType") @db.VarChar(20)
  /// BORRADOR | CERRADO
  status       String    @default("BORRADOR") @db.VarChar(20)
  totalExenta  Decimal   @default(0) @map("TotalExenta") @db.Decimal(14, 2)
  totalGravada Decimal   @default(0) @map("TotalGravada") @db.Decimal(14, 2)
  totalIva     Decimal   @default(0) @map("TotalIva") @db.Decimal(14, 2)
  generatedBy  String?   @map("GeneratedBy") @db.Uuid
  generatedAt  DateTime? @map("GeneratedAt") @db.Timestamptz
  fileUrl      String?   @map("FileUrl") @db.VarChar(500)
  notes        String?   @db.Text
  createdAt    DateTime  @default(now()) @map("CreatedAt") @db.Timestamptz

  @@unique([year, month, reportType])
  @@index([year, month], map: "IdxIvaReportPeriod")
  @@map("IvaReports")
  @@schema("fiscal")
}

// =============================================================================
// SCHEMA: hr — RRHH y Planilla
// =============================================================================

model Department {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique @db.VarChar(100)
  parentId    String?  @map("ParentId") @db.Uuid
  description String?  @db.VarChar(300)
  isActive    Boolean  @default(true) @map("IsActive")
  createdAt   DateTime @default(now()) @map("CreatedAt") @db.Timestamptz
  updatedAt   DateTime @default(now()) @map("UpdatedAt") @db.Timestamptz

  parent    Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children  Department[] @relation("DepartmentHierarchy")
  positions Position[]
  employees Employee[]

  @@index([parentId], map: "IdxDepartmentsParent")
  @@map("Departments")
  @@schema("hr")
}

model Position {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  departmentId String   @map("DepartmentId") @db.Uuid
  name         String   @db.VarChar(100)
  description  String?  @db.VarChar(500)
  isActive     Boolean  @default(true) @map("IsActive")
  createdAt    DateTime @default(now()) @map("CreatedAt") @db.Timestamptz
  updatedAt    DateTime @default(now()) @map("UpdatedAt") @db.Timestamptz

  department Department @relation(fields: [departmentId], references: [id])
  employees  Employee[]

  @@unique([departmentId, name])
  @@map("Positions")
  @@schema("hr")
}

model Bank {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @db.VarChar(150)
  code      String?  @unique @db.VarChar(10)
  swift     String?  @db.VarChar(20)
  isActive  Boolean  @default(true) @map("IsActive")
  createdAt DateTime @default(now()) @map("CreatedAt") @db.Timestamptz
  updatedAt DateTime @default(now()) @map("UpdatedAt") @db.Timestamptz

  employeeBankAccounts EmployeeBankAccount[]

  @@map("Banks")
  @@schema("hr")
}

model RequiredDocumentType {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                  String   @unique @db.VarChar(150)
